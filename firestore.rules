rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Bootstrapped Admin check using the runtime user's email
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "24eg107f29@anurag.edu.in" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATION HELPERS ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price > 0 &&
             data.imageUrl is string && data.imageUrl.size() <= 2048 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.userEmail is string && data.userEmail.size() <= 100 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.totalAmount is number && data.totalAmount > 0 &&
             data.status is string && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.shippingAddress is map;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.role is string && data.role in ['admin', 'user'];
    }

    // --- COLLECTION MATCH BLOCKS ---

    // 1. PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true; // Public catalog browsing
      
      allow create: if isAdmin() && isValidId(productId) &&
                      incoming().keys().hasAll(['name', 'price', 'imageUrl', 'category', 'stock']) &&
                      incoming().keys().size() == 5 &&
                      isValidProduct(incoming());

      allow update: if isAdmin() && isValidProduct(incoming());

      allow delete: if isAdmin();
    }

    // 2. ORDERS COLLECTION
    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      
      // Enforce list queries on server side. No blanket lists!
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isEmailVerified() && isValidId(orderId) &&
                      incoming().keys().hasAll(['userId', 'userEmail', 'items', 'totalAmount', 'status', 'shippingAddress']) &&
                      incoming().keys().size() == 6 &&
                      incoming().userId == request.auth.uid &&
                      incoming().status == 'pending' && // Orders must start as pending
                      isValidOrder(incoming());

      // Actions-based update pattern
      allow update: if isEmailVerified() && (
        isAdmin() && isValidOrder(incoming()) || 
        (
          existing().userId == request.auth.uid && 
          isValidOrder(incoming()) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
          incoming().status == 'cancelled' &&
          existing().status == 'pending'
        )
      );

      allow delete: if isAdmin();
    }

    // 3. USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();

      allow create: if isEmailVerified() && userId == request.auth.uid &&
                      incoming().keys().hasAll(['uid', 'email', 'role']) &&
                      incoming().keys().size() == 3 &&
                      incoming().uid == request.auth.uid &&
                      incoming().role == 'user' && // Prevent self-promoting to admin
                      isValidUser(incoming());

      allow update: if isEmailVerified() && userId == request.auth.uid &&
                      isValidUser(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['email']) &&
                      incoming().email == existing().email; // Role is immutable for users

      allow delete: if isAdmin();
    }
  }
}
